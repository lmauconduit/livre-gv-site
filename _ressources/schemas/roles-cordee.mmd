    end

    L3 -->|"Signal : Paré !"| S1
    S3 -->|"Signal : Arrivé !"| L4
    L4 -->|Rôles échangés\nsi nécessaire| S4

    style LEADER fill:#fdf0ee,stroke:#c0392b
    style SECOND fill:#edfaf3,stroke:#27ae60
